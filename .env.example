# Copy this file to .env and fill in your keys (the .env is gitignored).
# These mirror the GitHub Actions secrets so a local build embeds the same
# metadata API keys the CI build does. Without them, TMDB poster/cover lookups
# return "authentication required" and IGDB game art is disabled — the app
# still runs, just without artwork.
#
# Get a free TMDB key at: https://www.themoviedb.org/settings/api
# Get IGDB (Twitch) credentials at: https://dev.twitch.tv/console/apps
#
# Then build with: ./scripts/dev-build.sh
export BAT_TMDB_KEY=""
export BAT_IGDB_ID=""
export BAT_IGDB_SECRET=""
