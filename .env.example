# Copy this file to .env and fill in your keys (the .env is gitignored).
# These mirror the GitHub Actions secrets so a local build embeds the same
# metadata API keys the CI build does. Without them, TMDB poster/cover lookups
# return "authentication required" and IGDB game art is disabled — the app
# still runs, just without artwork.
#
# Get a free TMDB key at: https://www.themoviedb.org/settings/api
# Get IGDB (Twitch) credentials at: https://dev.twitch.tv/console/apps
# OpenSubtitles key — for LOCAL/personal builds ONLY. Get one free at:
#   https://www.opensubtitles.com/en/consumers (account → Consumers → New Consumer).
#   ⚠️ Do NOT put this in CI secrets / a distributed build. Unlike TMDB (no daily
#   cap), the OpenSubtitles FREE tier is 5 DOWNLOADS / 24h PER KEY — a shared
#   embedded key means 5 downloads/day for the ENTIRE userbase. Public builds must
#   let each user add their own key (Settings → Advanced). Series need no key
#   (Gestdown); this only affects MOVIE subtitle search.
#
# Then build with: ./scripts/dev-build.sh
export BAT_TMDB_KEY=""
export BAT_IGDB_ID=""
export BAT_IGDB_SECRET=""
export BAT_OS_KEY=""
