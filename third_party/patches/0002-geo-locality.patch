+	// BATorrent fork: geo-locality hook (see ip_helpers.hpp). Single global
+	// classifier — the app has one session, so no per-session dispatch needed.
+	namespace {
+		std::function<bool(address const&)> g_geo_local_fn;
+	}
+
+	bool is_geo_local(address const& a)
+	{
+		return g_geo_local_fn ? g_geo_local_fn(a) : false;
+	}
+
+	void set_geo_local_fn(std::function<bool(address const&)> fn)
+	{
+		g_geo_local_fn = std::move(fn);
+	}
